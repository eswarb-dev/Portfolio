# Vercel/frontend
# Public URL of your Cloudflare Worker stats API.
# This value is bundled into frontend JavaScript, so it is safe only for public URLs.
VITE_STATS_API_BASE_URL=https://eswar-portfolio-stats.eswar-portfolio.workers.dev

# Cloudflare Worker only
# Do not put these in Vercel frontend env vars unless the Worker also runs there.
# Set ADMIN_STATS_TOKEN with: wrangler secret put ADMIN_STATS_TOKEN
ADMIN_STATS_TOKEN=

# Resume request email notification through Resend.
# Set RESEND_API_KEY with: wrangler secret put RESEND_API_KEY
# Set RESUME_NOTIFY_EMAIL to the inbox that should receive resume requests.
RESEND_API_KEY=
RESUME_NOTIFY_EMAIL=eswarbalu28@gmail.com
RESUME_FILE_URL=https://xfgqwucmbxcnfpxtepbm.supabase.co/storage/v1/object/public/Resume/ESWAR_B_RESUME.pdf
RESUME_FROM_EMAIL=Eswar Portfolio <resume@eswar.me>

# Set SITE_ORIGIN in worker/wrangler.toml.
# Bind STATS_KV in worker/wrangler.toml after creating a Workers KV namespace.
