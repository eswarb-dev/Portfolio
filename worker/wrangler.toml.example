name = "eswar-portfolio-stats"
main = "stats-worker.js"
compatibility_date = "2026-06-09"

# Public frontend origins allowed to call this worker. Separate multiple origins with commas.
# Production should include the custom domain:
# SITE_ORIGIN = "https://eswar.me"
[vars]
SITE_ORIGIN = "https://eswar.me"
RESUME_NOTIFY_EMAIL = "eswarbalu28@gmail.com"
RESUME_FILE_URL = "https://xfgqwucmbxcnfpxtepbm.supabase.co/storage/v1/object/public/Resume/ESWAR_B_RESUME.pdf"
RESUME_FROM_EMAIL = "Eswar Portfolio <resume@eswar.me>"

# Create this namespace with:
# wrangler kv namespace create STATS_KV
[[kv_namespaces]]
binding = "STATS_KV"
id = "replace_with_your_kv_namespace_id"

# Set the private token with:
# wrangler secret put ADMIN_STATS_TOKEN
# Set the Resend email API key with:
# wrangler secret put RESEND_API_KEY
